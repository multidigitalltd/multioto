# Ready-to-use environment for the Docker deployment.
# Copy it to .env before the first `docker compose up`:  cp .env.docker .env
# APP_KEY is generated automatically on first boot.
# Enter Cardcom/Linet/Postmark/FlyWP/WAHA keys here or in the /admin settings page.

APP_NAME=Multioto
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jerusalem
APP_URL=https://app.multidigital.co.il
APP_DOMAIN=app.multidigital.co.il

APP_LOCALE=he
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_LEVEL=warning

# Database — points at the compose 'postgres' service.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=multioto
DB_USERNAME=multioto
DB_PASSWORD=multioto

# Redis — points at the compose 'redis' service.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
CACHE_STORE=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Mail — Postmark (fill POSTMARK_TOKEN, or set in the settings page).
MAIL_MAILER=postmark
POSTMARK_TOKEN=
MAIL_FROM_ADDRESS=support@multidigital.co.il
MAIL_FROM_NAME="Multi Digital"
SUPPORT_EMAIL=support@multidigital.co.il

# --- Integrations (enter here or in the /admin settings page) ---
CARDCOM_TERMINAL_NUMBER=
CARDCOM_API_NAME=
CARDCOM_API_PASSWORD=
CARDCOM_BASE_URL=https://secure.cardcom.solutions/api/v11
CARDCOM_WEBHOOK_SECRET=

LINET_LOGIN_ID=
LINET_KEY=
LINET_COMPANY_ID=
LINET_BASE_URL=https://app.linet.org.il/api
LINET_EMAIL_DOCUMENT=true
# Account-specific codes from your Linet setup — verify before issuing real documents:
LINET_DOCTYPE=
LINET_VAT_CAT_TAXABLE=1
LINET_VAT_CAT_EXEMPT=
LINET_PAYMENT_TYPE=3

WAHA_BASE_URL=http://waha:3000
WAHA_API_KEY=
WAHA_SESSION=default
WAHA_WEBHOOK_SECRET=
WAHA_BROADCAST_THROTTLE=30

EMAIL_WEBHOOK_SECRET=

# --- Hosting panel (FlyWP) ---
HOSTING_DRIVER=log
FLYWP_BASE_URL=https://app.flywp.com/api/v1
FLYWP_API_TOKEN=
FLYWP_SERVER_ID=
FLYWP_MAINTENANCE_PATH=servers/{server}/sites/{site}/maintenance

# --- Billing / monitoring ---
BILLING_VAT_RATE=0.18
CARD_UPDATE_LINK_TTL_HOURS=72
MONITOR_INTERVAL_MINUTES=5
MONITOR_TIMEOUT_SECONDS=10
MONITOR_FAILURES_TO_INCIDENT=2

# --- AI Tier-1 (optional, off by default) ---
AI_ENABLED=false
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
AI_EFFORT=low
